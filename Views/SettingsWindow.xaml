<Window x:Class="VrcGroupCreator.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:VrcGroupCreator.ViewModels"
        mc:Ignorable="d"
        Title="Settings" Height="520" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        WindowStyle="None" AllowsTransparency="False"
        Icon="pack://application:,,,/app_icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="56" GlassFrameThickness="0" CornerRadius="0" ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <!-- DataContext is set via Dependency Injection in code-behind -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Padding="16,0" Height="56">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Cog" Width="26" Height="26" VerticalAlignment="Center" />
                    <TextBlock Text="Settings" Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="12,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Foreground="White" Click="CloseAndRevert_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                </Button>
            </Grid>
        </materialDesign:ColorZone>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- Theme Color Section -->
                <TextBlock Text="Theme Color" Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           Opacity="0.5" Margin="4,0,0,12" />

                <materialDesign:Card Padding="20" materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>

                        <!-- Sliders -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Hue" FontSize="11" Opacity="0.55" Margin="0,0,0,2" />
                            <Slider Value="{Binding Hue}" Minimum="0" Maximum="360"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="0,0,0,14" />

                            <TextBlock Text="Saturation" FontSize="11" Opacity="0.55" Margin="0,0,0,2" />
                            <Slider Value="{Binding Saturation}" Minimum="0" Maximum="1"
                                    TickFrequency="0.01" Margin="0,0,0,14" />

                            <TextBlock Text="Lightness" FontSize="11" Opacity="0.55" Margin="0,0,0,2" />
                            <Slider Value="{Binding Luminance}" Minimum="0" Maximum="1"
                                    TickFrequency="0.01" Margin="0,0,0,0" />
                        </StackPanel>

                        <!-- Color Preview + Reset -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="72" Height="72" CornerRadius="36"
                                    BorderThickness="0"
                                    HorizontalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.45" />
                                </Border.Effect>
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding PrimaryColor}" />
                                </Border.Background>
                            </Border>
                            <TextBlock Text="{Binding PrimaryColor}" HorizontalAlignment="Center"
                                       Margin="0,10,0,0" FontSize="10" FontWeight="SemiBold" Opacity="0.6" />
                            <Button Content="Reset Color"
                                    Command="{Binding ResetCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,12,0,0"
                                    Height="30" Padding="10,0"
                                    FontSize="11" />
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Developer Section -->
                <TextBlock Text="Developer" Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           Opacity="0.5" Margin="4,0,0,12" />

                <materialDesign:Card Padding="20" materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Debug Console -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Debug Console" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" IsChecked="{Binding EnableDebugConsole}"
                                          VerticalAlignment="Center" Margin="16,0,0,0" />
                        </Grid>

                        <!-- File Logging -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Log to File" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" IsChecked="{Binding EnableFileLogging}"
                                          VerticalAlignment="Center" Margin="16,0,0,0" />
                        </Grid>
                    </Grid>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                Background="{DynamicResource MaterialDesignPaper}"
                Padding="16,12">
            <Button Content="Save &amp; Close" Command="{Binding SaveCommand}" Click="Close_Click"
                    HorizontalAlignment="Right" />
        </Border>
    </Grid>
</Window>
